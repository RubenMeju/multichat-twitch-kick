{
  "name": "stream-chat-vscode",
  "displayName": "Twitch mejudev",
  "description": "Chat y viewers de Twitch integrado en VSCode",
  "version": "0.1.0",
  "publisher": "mejudev",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenMeju/stream-chat-vscode"
  },
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "stream-chat-vscode.chat",
          "name": "💬 Twitch Chat",
          "icon": "icon.png"
        }
      ]
    },
    "configuration": {
      "title": "Twitch mejudev",
      "properties": {
        "stream-chat-vscode.clientId": {
          "type": "string",
          "description": "Tu Twitch Client ID (dev.twitch.tv)"
        },
        "stream-chat-vscode.clientSecret": {
          "type": "string",
          "description": "Tu Twitch Client Secret (dev.twitch.tv)"
        },
        "stream-chat-vscode.channel": {
          "type": "string",
          "description": "Tu canal de Twitch (ej: mejudev)"
        },
        "stream-chat-vscode.serverUrl": {
          "type": "string",
          "description": "URL de tu servidor WebSocket (ej: wss://tu-app.onrender.com)"
        }
      }
    }
  }
}
